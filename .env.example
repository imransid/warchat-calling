# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_URL=https://your-app.com
PORT=3000
CORS_ORIGIN=*

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/warmchats_calling?schema=public"

# ============================================
# TELNYX (Primary Provider - Client's Account)
# ============================================
# Get these from: https://portal.telnyx.com
# Client owns this account directly
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_CONNECTION_ID=your_telnyx_connection_id_here
TELNYX_MESSAGING_PROFILE_ID=your_telnyx_messaging_profile_id_here
# Credential Connection (SIP) — owns the per-agent WebRTC SIP users
TELNYX_CREDENTIAL_CONNECTION_ID=your_telnyx_credential_connection_id_here
TELNYX_SIP_DOMAIN=warmchats.sip.telnyx.com
# base64-encoded Ed25519 public key from Telnyx portal — used to verify
# webhook signatures (header `telnyx-signature-ed25519`)
TELNYX_PUBLIC_KEY=

# ============================================
# TWILIO (Optional - Not Used by Default)
# ============================================
# Uncomment only if switching to Twilio
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ============================================
# REDIS (BullMQ Job Queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# AUTHENTICATION (JWT)
# ============================================
# MUST match the JWT_SECRET_KEY value in the Flask main API (Warcmchats-APP/.env)
# Tokens are HS256, with claims: sub (user UUID), org_id (workspace UUID), role
JWT_SECRET_KEY=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# ============================================
# CALLING CONFIGURATION (Client Requirements)
# ============================================
DEFAULT_RING_TIMEOUT=25
AUTO_CHARGE_OVERAGE=true
DEFAULT_MISSED_CALL_SMS="Currently in an appointment. I will call you back shortly or text me please."

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=
ENABLE_DOCS=true
