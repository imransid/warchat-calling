// Prisma Schema for WarmChats Calling Module
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PHONE NUMBER MANAGEMENT
// ============================================

enum PhoneNumberStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  RELEASED
}

model PhoneNumber {
  id           String            @id @default(uuid())
  phoneNumber  String            @unique
  provider     String // 'telnyx' (only supported provider)
  providerSid  String            @unique // Telnyx phone-number ID
  status       PhoneNumberStatus @default(PROVISIONING)
  capabilities Json // { voice: true, sms: true }

  // Assignment
  assignedToUserId String?   @unique
  assignedToUser   User?     @relation(fields: [assignedToUserId], references: [id])
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])

  // Metadata
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  releasedAt DateTime?

  // Relations
  calls Call[]

  @@index([workspaceId])
  @@index([assignedToUserId])
  @@map("phone_numbers")
}

// ============================================
// CALL RECORDS
// ============================================

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELED
}

model Call {
  id String @id @default(uuid())

  // Call Identification
  providerCallSid String        @unique // Telnyx call_control_id
  direction       CallDirection
  status          CallStatus    @default(INITIATED)

  // Participants
  fromNumber String
  toNumber   String
  leadId     String
  lead       Lead   @relation(fields: [leadId], references: [id])
  agentId    String
  agent      User   @relation(fields: [agentId], references: [id])

  // Phone Numbers
  businessNumberId String
  businessNumber   PhoneNumber @relation(fields: [businessNumberId], references: [id])
  agentPhoneNumber String // Agent's real phone number
  customerNumber   String // Customer's phone number

  // Call Details
  duration     Int     @default(0) // Duration in seconds
  recordingUrl String?
  recordingSid String?

  // Timestamps
  initiatedAt DateTime  @default(now())
  ringingAt   DateTime?
  answeredAt  DateTime?
  completedAt DateTime?

  // Parallel-ring leg tracking (web + cell fork)
  webLegSid   String? // call_control_id of the SIP/web leg
  phoneLegSid String? // call_control_id of the PSTN/cell leg
  answeredVia String? // 'web' | 'phone' — whichever leg picked up first

  // Outbound origin: 'web' (browser SDK) or 'phone' (agent-first PSTN)
  origin String? @default("phone")

  // Metadata
  providerMetadata Json? // Raw provider webhook data
  errorMessage     String?

  // Relations
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  callEvents   CallEvent[]
  usageRecords UsageRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([agentId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
  @@map("calls")
}

// ============================================
// CALL EVENTS (Event Sourcing)
// ============================================

enum CallEventType {
  CALL_INITIATED
  AGENT_RINGING
  AGENT_ANSWERED
  CUSTOMER_RINGING
  CUSTOMER_ANSWERED
  CALL_CONNECTED
  CALL_COMPLETED
  CALL_FAILED
  CALL_NO_ANSWER
  CALL_BUSY
  CALL_CANCELED
  MISSED_CALL_SMS_SENT
  // Parallel-ring + call-waiting events
  WEB_LEG_RINGING
  PHONE_LEG_RINGING
  ANSWERED_ON_WEB
  ANSWERED_ON_PHONE
  LOSER_LEG_CANCELED
  BUSY_AGENT_OCCUPIED
}

model CallEvent {
  id     String @id @default(uuid())
  callId String
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  eventType CallEventType
  timestamp DateTime      @default(now())
  payload   Json // Event-specific data

  // Provider webhook data
  providerEventId String? @unique
  webhookPayload  Json?

  @@index([callId, timestamp])
  @@map("call_events")
}

// ============================================
// USAGE METERING
// ============================================

enum BillingCycleStatus {
  ACTIVE
  COMPLETED
  SETTLED
}

model BillingCycle {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  startDate DateTime
  endDate   DateTime
  status    BillingCycleStatus @default(ACTIVE)

  // Limits
  planMinuteLimit Int // Minutes included in plan
  overageRate     Decimal @db.Decimal(10, 4) // Per-minute overage cost

  // Usage
  usageRecords UsageRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, startDate])
  @@map("billing_cycles")
}

model UsageRecord {
  id String @id @default(uuid())

  callId String
  call   Call   @relation(fields: [callId], references: [id])

  billingCycleId String
  billingCycle   BillingCycle @relation(fields: [billingCycleId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  // Metered Usage
  minutes   Decimal @db.Decimal(10, 4) // Fractional minutes
  cost      Decimal @db.Decimal(10, 4) // Cost for this call
  isOverage Boolean @default(false)

  recordedAt DateTime @default(now())

  @@index([billingCycleId, workspaceId])
  @@index([agentId, billingCycleId])
  @@map("usage_records")
}

// ============================================
// CONFIGURATION
// ============================================

model CallingConfiguration {
  id          String    @id @default(uuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Inbound Settings
  ringTimeout           Int    @default(25) // Seconds - Client requirement: 25 seconds
  missedCallSmsTemplate String @default("Currently in an appointment. I will call you back shortly or text me please.") // Client's exact template
  // 'parallel' (web + cell simultaneously), 'web_first', 'phone_first'
  ringStrategy          String @default("parallel")

  // Provider Settings
  provider           String @default("telnyx") // Client uses Telnyx only
  providerAccountSid String @db.Text
  providerAuthToken  String @db.Text // Should be encrypted

  // Webhook Settings
  webhookUrl           String?
  webhookRetryAttempts Int     @default(3)
  webhookRetryDelay    Int     @default(5000) // Milliseconds

  // Feature Flags
  callingEnabled    Boolean @default(true)
  recordingEnabled  Boolean @default(false)
  autoChargeOverage Boolean @default(true) // Client requirement: auto-charge, don't block

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("calling_configurations")
}

// ============================================
// WEBHOOK TRACKING (Idempotency)
// ============================================

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  RETRYING
}

model WebhookLog {
  id String @id @default(uuid())

  // Provider webhook identification
  providerEventId String @unique
  provider        String // 'telnyx' (only supported provider)
  eventType       String

  // Processing
  status      WebhookStatus @default(RECEIVED)
  retryCount  Int           @default(0)
  lastRetryAt DateTime?
  processedAt DateTime?

  // Payload
  payload      Json
  errorMessage String?

  // Related entities
  callId      String?
  workspaceId String?

  receivedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerEventId])
  @@index([status, retryCount])
  @@map("webhook_logs")
}

// ============================================
// SUPPORTING MODELS (Simplified)
// ============================================

model Workspace {
  id   String @id @default(uuid())
  name String

  // Relations
  phoneNumbers         PhoneNumber[]
  calls                Call[]
  billingCycles        BillingCycle[]
  usageRecords         UsageRecord[]
  callingConfiguration CallingConfiguration?
  users                User[]
  leads                Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspaces")
}

model User {
  id          String  @id @default(uuid())
  // email/name are nullable because the calling backend lazily upserts User
  // rows from JWT claims (sub + org_id only) — the Flask main API is the
  // system-of-record for these fields.
  email       String? @unique
  name        String?
  phoneNumber String? // Agent's real phone number (for cell-phone leg of parallel ring)

  // Telnyx SIP Credential used by @telnyx/webrtc in the browser. Created
  // on-demand when the agent first requests a WebRTC login token.
  telnyxCredentialId String? @unique
  telnyxSipUri       String? // e.g. sip:agent-uuid@warmchats.sip.telnyx.com

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Relations
  assignedNumber PhoneNumber?
  calls          Call[]
  usageRecords   UsageRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("users")
}

model Lead {
  id          String  @id @default(uuid())
  phoneNumber String
  name        String?
  email       String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Relations
  calls Call[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, phoneNumber])
  @@map("leads")
}
